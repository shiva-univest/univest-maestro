# ============================================
# Univest Maestro - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- App Configuration ---
APP_ID=com.univest.capp.uat
BUNDLE_ID=com.univest.capp.uat

# --- Test Credentials (UAT) ---
CONTACT_NUMBER=9876543210
OTP=0000

# --- APK Path ---
# Path to pre-built APK (relative to this repo or absolute)
FLUTTER_PROJECT_DIR=./univest-build/your-app.apk

# --- Firebase Test Lab ---
FIREBASE_PROJECT_ID=your-firebase-project-id
GCP_SERVICE_ACCOUNT_KEY_PATH=gcp-key.json

# --- Device Configuration ---
# Run: gcloud firebase test android models list  (to see available models)
DEVICE_MODEL=MediumPhone.arm
DEVICE_VERSION=30
DEVICE_LOCALE=en
DEVICE_ORIENTATION=portrait

# --- Test Execution ---
# Test suite to run: smoke | regression
TEST_SUITE=smoke
# Timeout for Firebase Test Lab runs (in minutes)
TEST_TIMEOUT=15m

# --- Artifacts ---
ARTIFACTS_DIR=./artifacts
