# ============================================
# Univest Maestro - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- App Configuration ---
APP_ID=com.univest.capp.uat
BUNDLE_ID=com.univest.capp.uat

# --- Test Credentials (UAT) ---
CONTACT_NUMBER=9876543210
OTP=0000

# --- Flutter Project ---
# Path to the Flutter project root (relative to this repo)
FLUTTER_PROJECT_DIR=../univest

# --- Firebase Test Lab ---
FIREBASE_PROJECT_ID=
GCP_SERVICE_ACCOUNT_KEY_PATH=

# --- Device Configuration ---
DEVICE_MODEL=Pixel2
DEVICE_VERSION=30
DEVICE_LOCALE=en
DEVICE_ORIENTATION=portrait

# --- Test Execution ---
# Test suite to run: smoke | regression
TEST_SUITE=smoke
# Timeout for Firebase Test Lab runs (in minutes)
TEST_TIMEOUT=15m

# --- Artifacts ---
ARTIFACTS_DIR=./artifacts
