# ============================================
# Univest Maestro - Environment Configuration
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# --- App Configuration ---
APP_ID=com.univest.capp.uat
BUNDLE_ID=com.univest.capp.uat

# --- Test Credentials (UAT) ---
CONTACT_NUMBER=9876543210
OTP=0000

# --- APK Path ---
# Place your APK in univest-build/ directory
APK_PATH=./univest-build/your-app.apk

# --- Test Execution ---
# Test suite to run: smoke | regression
TEST_SUITE=smoke

# --- Artifacts ---
ARTIFACTS_DIR=./artifacts
